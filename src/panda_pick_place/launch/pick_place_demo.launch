<?xml version="1.0"?>
<launch>
  <arg name="anygrasp_python" default="$(optenv ANYGRASP_PYTHON /usr/bin/python3)" />
  <!-- 启动 panda_moveit_config 的 demo_gazebo.launch -->
  <include file="$(find panda_moveit_config)/launch/demo_gazebo.launch">
    <arg name="paused" value="false"/>
    <arg name="gazebo_gui" value="true"/>
  </include>

  <node pkg="tf" type="static_transform_publisher"
      name="depth_camera_tf"
      args="0.426685 -0.009627 0.533417 1.57 3.14 0 world depth_camera_link 100" />


  <node pkg="grasp_detector_ros" type="detector_node.py" name="grasp_detector_node" output="screen"
          launch-prefix="$(arg anygrasp_python)">
    </node>

  <!-- 等待Gazebo完全启动
  <arg name="wait_time" default="5.0"/> -->

  <!-- 在Gazebo中生成立方体物体 -->


  <!-- 启动抓取放置节点 -->
  <!--
  <node name="pick_place_node"
        pkg="panda_pick_place" type="pick_place_node.py"
        output="screen" />
  -->

</launch>
