  <arg name="soft_grasp_under_width_tolerance" default="0.018" />
  <arg name="soft_grasp_over_width_tolerance" default="0.008" />
  <arg name="soft_grasp_min_width" default="0.035" />
  <arg name="soft_grasp_max_width" default="0.078" />
  <arg name="force_grasp_verify_after_close" default="true" />
  <arg name="force_grasp_verify_after_retreat" default="true" />
  <arg name="force_grasp_verify_wait_sec" default="0.25" />
  <arg name="gazebo_functional_grasp_verify" default="true" />
  <arg name="gazebo_functional_grasp_max_object_to_ee" default="0.14" />
  <arg name="gazebo_functional_grasp_min_object_motion" default="0.015" />
  <arg name="gazebo_functional_grasp_min_follow_ratio" default="0.35" />
