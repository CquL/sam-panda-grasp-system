  <arg name="pointcloud_show_output_grasps" default="false" />
  <arg name="pointcloud_grasp_top_n" default="6" />
  <arg name="pointcloud_overview_grasp_top_n" default="4" />
  <arg name="pointcloud_overview_use_rgb_texture" default="true" />
  <arg name="pointcloud_focus_object_id" default="-1" />
  <arg name="pointcloud_focus_selection_mode" default="largest" />
  <arg name="pointcloud_show_focus_object" default="false" />
  <arg name="pointcloud_show_focus_pure_object" default="$(arg pointcloud_show_focus_object)" />
  <arg name="pointcloud_show_focus_overlay_object" default="$(arg pointcloud_show_focus_object)" />
  <arg name="pointcloud_show_focus_pure_o3d" default="$(arg pointcloud_show_focus_pure_object)" />
  <arg name="pointcloud_show_focus_overlay_o3d" default="$(arg pointcloud_show_focus_overlay_object)" />
