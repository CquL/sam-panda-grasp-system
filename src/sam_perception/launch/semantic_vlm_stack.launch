  <arg name="pointcloud_show_raw_o3d" default="false" />
  <arg name="pointcloud_show_object_overview_o3d" default="false" />
  <arg name="pointcloud_show_background_o3d" default="false" />
  <arg name="pointcloud_white_background" default="true" />
