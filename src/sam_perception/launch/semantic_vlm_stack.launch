    <arg name="show_all_object_focus_overlay_o3d" value="$(arg pointcloud_show_all_object_focus_overlay_o3d)" />
    <arg name="all_object_detail_max_windows" value="$(arg pointcloud_all_object_detail_max_windows)" />
    <arg name="focus_use_rgb_texture" value="$(arg pointcloud_focus_use_rgb_texture)" />
    <arg name="save_snapshots" value="$(arg pointcloud_save_snapshots)" />
    <arg name="grasp_mesh_radius" value="$(arg pointcloud_grasp_mesh_radius)" />
    <arg name="grasp_center_radius" value="$(arg pointcloud_grasp_center_radius)" />
  </include>
</launch>
